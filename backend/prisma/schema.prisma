generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Clientes {
  id           Int            @id @default(autoincrement())
  nome         String         @db.VarChar(100)
  telefone     String         @unique @db.VarChar(15)
  email        String?        @unique @db.VarChar(100)
  dataCadastro DateTime       @default(now()) @map("data_cadastro") @db.DateTime(0)
  agendamentos Agendamentos[]

  @@map("clientes")
}

model Profissionais {
  id            Int            @id @default(autoincrement())
  nome          String
  especialidade String
  agendamentos  Agendamentos[]

  @@map("profissionais")
}

model Servicos {
  id           Int            @id @default(autoincrement())
  descricao    String
  preco        Float
  agendamentos Agendamentos[]

  @@map("servicos")
}

model Agendamentos {
  id             Int      @id @default(autoincrement())
  dataHora       DateTime
  clienteId      Int
  profissionalId Int
  servicoId      Int

  cliente      Clientes      @relation(fields: [clienteId], references: [id])
  profissional Profissionais @relation(fields: [profissionalId], references: [id])
  servico      Servicos      @relation(fields: [servicoId], references: [id])

  @@map("agendamentos")
}
